)

stardoc(
    name = "vunit_modelsim_sim_doc",
    out = "src/vunit_modelsim_sim.md",
    input = "//vunit:vunit_modelsim_sim.bzl",
    table_of_contents_template = "@io_bazel_stardoc//stardoc:templates/markdown_tables/table_of_contents.vm",
    tags = ["manual"],
    deps = ["//vunit:bzl_lib"],
)

stardoc(
    name = "vunit_questa_sim_doc",
    out = "src/vunit_questa_sim.md",
    input = "//vunit:vunit_questa_sim.bzl",
    table_of_contents_template = "@io_bazel_stardoc//stardoc:templates/markdown_tables/table_of_contents.vm",
    tags = ["manual"],
    deps = ["//vunit:bzl_lib"],
