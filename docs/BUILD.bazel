load("@io_bazel_stardoc//stardoc:stardoc.bzl", "stardoc")
load("@rules_rust_mdbook//:defs.bzl", "mdbook", "mdbook_server")
load("@rules_shell//shell:sh_binary.bzl", "sh_binary")

stardoc(
    name = "vunit_test_doc",
    out = "src/vunit_test.md",
    input = "//vunit:vunit_test.bzl",
    table_of_contents_template = "@io_bazel_stardoc//stardoc:templates/markdown_tables/table_of_contents.vm",
    tags = ["manual"],
    deps = ["//vunit:bzl_lib"],
)

stardoc(
    name = "vunit_toolchain_doc",
    out = "src/vunit_toolchain.md",
