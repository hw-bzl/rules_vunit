    table_of_contents_template = "@io_bazel_stardoc//stardoc:templates/markdown_tables/table_of_contents.vm",
    tags = ["manual"],
    deps = ["//vunit:bzl_lib"],
)

stardoc(
    name = "vunit_ghdl_sim_doc",
    out = "src/vunit_ghdl_sim.md",
    input = "//vunit:vunit_ghdl_sim.bzl",
    table_of_contents_template = "@io_bazel_stardoc//stardoc:templates/markdown_tables/table_of_contents.vm",
